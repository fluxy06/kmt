# Copy to .env and fill in: cp .env.example .env
# PUBLIC values only — never put CLOUDINARY_URL / api_secret here:
# everything in this file ends up in the JS bundle.

# Cloud name from Cloudinary Console -> Dashboard -> Cloud name
VITE_CLOUDINARY_CLOUD_NAME=

# Unsigned upload preset from Settings -> Upload -> Upload presets
VITE_CLOUDINARY_UPLOAD_PRESET=

# Optional target folder in Media Library
VITE_CLOUDINARY_FOLDER=
