# Cloudinary settings for frontend uploads (PUBLIC values only — never put
# CLOUDINARY_URL / api_secret here: everything in this file ends up in the JS bundle)

# 1) Cloud name from Cloudinary Console -> Dashboard -> Cloud name
#    Важно: это НЕ username/profile name. В вашем случае: dphmqaruu
VITE_CLOUDINARY_CLOUD_NAME=dphmqaruu

# 2) unsigned upload preset from Settings -> Upload -> Upload presets
VITE_CLOUDINARY_UPLOAD_PRESET=kmt-preset

# 3) optional target folder in Media Library
VITE_CLOUDINARY_FOLDER=kmt-source
